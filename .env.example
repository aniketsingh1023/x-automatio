# ============================================================
# X-Automatio Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your .env file to git
# ============================================================

# ── Google Gemini API ────────────────────────────────────────
# Free tier: https://ai.google.dev/
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Twitter API v2 (Primary posting method) ──────────────────
# Create an app at: https://developer.twitter.com/en/apps
# Requires "Read and Write" permissions on your app
# Under "User authentication settings", enable OAuth 1.0a
TWITTER_APP_KEY=your_app_key_here
TWITTER_APP_SECRET=your_app_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here

# ── Twitter Account (Puppeteer fallback ONLY) ────────────────
# Used only when Twitter API is unavailable or rate-limited
# These are your login credentials, handle with extreme care
TWITTER_USERNAME=your_twitter_handle_without_at
TWITTER_PASSWORD=your_twitter_password
TWITTER_EMAIL=your_twitter_email@example.com

# ── Runtime Options ──────────────────────────────────────────
# Set DRY_RUN=true to generate thread without posting
DRY_RUN=false

# Set FORCE_PUPPETEER=true to skip the API and use browser automation
FORCE_PUPPETEER=false

# Log verbosity: error | warn | info | debug
LOG_LEVEL=info

# Number of articles to include in each thread (3-5 recommended)
TOP_ARTICLES_COUNT=5

# ── Puppeteer ────────────────────────────────────────────────
# Only set this if you need to override the Chromium path
# GitHub Actions sets this automatically via the workflow
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
